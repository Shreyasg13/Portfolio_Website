# Copy to .env.local for local development
# Set these as GitHub Secrets for CI:

# Netlify (required for CI deploy)
# Get from: app.netlify.com → User Settings → Personal access tokens
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token

# Get from: app.netlify.com → Site Settings → General → Site ID
NETLIFY_SITE_ID=your_netlify_site_id

# Google Analytics 4 (optional but recommended for visitor tracking)
# Get from: analytics.google.com → Admin → Data Streams → Measurement ID
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX
