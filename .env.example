# Copy to .env.local for local development
# Set these as GitHub Secrets for CI:

# Netlify (required for CI deploy)
# Get from: app.netlify.com → User Settings → Personal access tokens
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token

# Get from: app.netlify.com → Site Settings → General → Site ID
NETLIFY_SITE_ID=your_netlify_site_id

# Google Analytics 4 (optional but recommended for visitor tracking)
# Get from: analytics.google.com → Admin → Data Streams → Measurement ID
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# "Ask Shreyash" AI chat widget — set as a Netlify site environment variable
# (Site settings → Environment variables), NOT a GitHub secret — read at
# function runtime, not build time.
# Get from: openrouter.ai → Keys. Set a spend cap there since this key
# powers a public-facing endpoint.
OPENROUTER_API_KEY=your_openrouter_api_key

# Admin consoles (/admin conversations, /admin/visitors visitor log) —
# private views not meant for the public. Set as a Netlify site environment
# variable. Pick your own passphrase; both consoles stay inert (503) until
# this is set.
ADMIN_PASSWORD=choose_a_passphrase

# "Ask Shreyash" voice output — set as Netlify site environment variables
# (Site settings → Environment variables), NOT GitHub secrets — read at
# function runtime, not build time. Both are optional; without either set,
# voice output silently falls back to each visitor's browser TTS voice
# (which varies per browser) instead of erroring.
#
# Primary voice — Kokoro-82M (open-source, Apache-2.0, free) via Hugging
# Face's serverless Inference API. Get a token from:
# huggingface.co → Settings → Access Tokens (read scope is enough).
# Free-tier serverless models cold-start and can be briefly unavailable;
# tts.mjs falls back to ElevenLabs (if configured) or the browser voice.
HUGGINGFACE_API_KEY=your_huggingface_api_token

# Fallback voice — ElevenLabs (paid). Get from: elevenlabs.io → Profile →
# API Keys. Set a spend/character cap there since this key powers a
# public-facing endpoint.
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Optional — defaults to ElevenLabs' premade "Adam" voice if unset. Find
# other voice IDs at elevenlabs.io/app/voice-library.
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
